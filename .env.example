# BookVault Environment Variables
# Copy to .env and adjust

# Storage backend: "local" or "s3"
BOOKVAULT_STORAGE_PROVIDER=local

# Local storage path (when provider=local)
BOOKVAULT_STORAGE_PATH=./storage

# S3 configuration (when provider=s3)
BOOKVAULT_S3_ENDPOINT=http://localhost:9000
BOOKVAULT_S3_REGION=us-east-1
BOOKVAULT_S3_BUCKET=bookvault
BOOKVAULT_S3_ACCESS_KEY=bookvault
BOOKVAULT_S3_SECRET_KEY=bookvault-secret
BOOKVAULT_S3_PATH_STYLE=true

# Database
# SQLite: sqlite:///data/bookvault.db?mode=rwc
# Postgres: postgres://user:password@host:5432/bookvault
BOOKVAULT_DATABASE_URL=sqlite:///data/bookvault.db?mode=rwc

# Server
BOOKVAULT_PORT=8080
BOOKVAULT_HOST=0.0.0.0

# Auth
BOOKVAULT_AUTH_MODE=open
BOOKVAULT_SESSION_TTL_DAYS=30
BOOKVAULT_SESSION_IDLE_DAYS=7

# CORS
BOOKVAULT_CORS_ORIGIN=*

# Logging
BOOKVAULT_LOG_LEVEL=info

# Config file path (can override all above)
BOOKVAULT_CONFIG=bookvault.toml

# Web build directory (for serving SPA in production)
BOOKVAULT_WEB_DIR=./web/build
