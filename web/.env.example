# Public API URL for the BookVault backend.
# Set this to point to your Rust API server.
# Leave empty for same-origin (dev mode or Caddy reverse proxy).
#
# Examples:
#   PUBLIC_API_URL=""                    - same-origin (default)
#   PUBLIC_API_URL="http://localhost:8080" - local development backend
#   PUBLIC_API_URL="https://api.example.com" - remote VPS
PUBLIC_API_URL=""
